import sqlite3
import constVaribel
def create_database_and_table():
    conn = sqlite3.connect(constVaribel.database)
    c = conn.cursor()
    c.execute("""CREATE TABLE IF NOT EXISTS tracks(
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            title TEXT,
            album TEXT,
            artist TEXT,
            year INTERGER) 
    """)
    conn.commit()
    conn.close()
print("Staring..")
create_database_and_table()
print("Table created")